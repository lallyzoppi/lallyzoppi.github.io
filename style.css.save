/* RESET */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* BASE */
body {
  font-family: Arial, Helvetica, sans-serif;
  background-color: #0b1220;
  color: #e5e7eb;
  line-height: 1.6;
}

/* LAYOUT */
.container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 2rem;
}

/* HEADER */
header {
  text-align: center;
  padding-top: 3rem;
  padding-bottom: 2rem;
}

h1 {
  font-size: 3rem;
  margin-bottom: 0.5rem;
}

p {
  color: #9ca3af;
}

/* SECTION TITLE */
h2 {
  margin-bottom: 1.5rem;
  font-size: 2rem;
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1.5rem;
}

/* CARD */
.card {
  display: block;
  background-color: #111827;
  padding: 1.5rem;
  border-radius: 12px;
  text-decoration: none;
  color: white;
  transition: 0.2s ease;
  border: 1px solid #1f2937;
}

.card:hover {
  transform: translateY(-4px);
  background-color: #1f2937;
}

/* FOOTER */
.footer {
  text-align: center;
  margin-top: 4rem;
  color: #6b7280;
}
